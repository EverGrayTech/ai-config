{
  "name": "@evergraytech/ai-config",
  "version": "0.1.0",
  "description": "Local-first AI configuration layer enabling zero-setup defaults and optional bring-your-own-key model access across providers",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EverGrayTech/ai-config.git"
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc -p tsconfig.json",
    "lint": "pnpm biome check .",
    "test": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/react": "^19.1.2",
    "@vitest/coverage-v8": "^3.0.8",
    "react": "^19.1.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
